# YouTube Data API v3
YOUTUBE_API_KEY=your_youtube_data_api_key_here

# LLM Backend: "claude" (default) or "local" (Ollama)
LLM_BACKEND=claude

# Anthropic Claude API (required when LLM_BACKEND=claude)
ANTHROPIC_API_KEY=your_anthropic_api_key_here
CLAUDE_MODEL=claude-sonnet-4-6
CLAUDE_MAX_TOKENS=8096

# Local LLM via Ollama (required when LLM_BACKEND=local)
LOCAL_LLM_URL=http://localhost:11434/v1
LOCAL_LLM_MODEL=gemma3:12b

# Data fetching limits
MAX_VIDEOS=50
MAX_COMMENTS_PER_VIDEO=100

# Transcript language priority (comma-separated)
TRANSCRIPT_LANGUAGES=ja,zh-Hant,zh-Hans,en

# Storage paths
DATA_DIR=./data
REPORTS_DIR=./reports
