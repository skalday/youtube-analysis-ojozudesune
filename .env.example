# YouTube Data API v3
# 取得方式：https://console.cloud.google.com/apis/credentials
YOUTUBE_API_KEY=your_youtube_data_api_key_here

# Anthropic Claude API
# 取得方式：https://console.anthropic.com/
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# 預設頻道（可在執行時用 --channel 覆寫）
DEFAULT_CHANNEL_ID=

# 資料抓取設定
MAX_VIDEOS=20
MAX_COMMENTS_PER_VIDEO=100

# 快取有效時間（小時），超過後重新抓取
CACHE_TTL_HOURS=24

# 逐字稿語言優先順序（逗號分隔）
TRANSCRIPT_LANGUAGES=ja,zh-Hant,zh-Hans,en

# Claude 模型設定
CLAUDE_MODEL=claude-sonnet-4-6
CLAUDE_MAX_TOKENS=8096
